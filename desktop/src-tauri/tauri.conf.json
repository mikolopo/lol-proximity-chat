{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoLProximityChat",
  "version": "1.0.0",
  "identifier": "com.mikolopo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LoLProximityChat",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mikolopo/lol-proximity-chat/releases/latest/download/latest.json"
      ],
      "pubkey": "RWSb0WdiVYVHu8N4IfmEehYHwMF31189Lj3NHfFja7rDGiij/Iz+w0Aj"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "python-worker"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
